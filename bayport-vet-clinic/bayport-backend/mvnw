set -euf

BASE_DIR="$(cd "$(dirname "$0")" && pwd -P)"
WRAPPER_DIR="${BASE_DIR}/.mvn/wrapper"
WRAPPER_PROPERTIES="${WRAPPER_DIR}/maven-wrapper.properties"
WRAPPER_JAR="${WRAPPER_DIR}/maven-wrapper.jar"

if [ ! -f "${WRAPPER_PROPERTIES}" ]; then
  echo "Cannot find ${WRAPPER_PROPERTIES}" >&2
  exit 1
fi

distributionUrl=$(grep -E "^distributionUrl=" "${WRAPPER_PROPERTIES}" | cut -d'=' -f2-)
wrapperUrl=$(grep -E "^wrapperUrl=" "${WRAPPER_PROPERTIES}" | cut -d'=' -f2-)

need_cmd() {
  command -v "$1" >/dev/null 2>&1
}

download() {
  url="$1"
  dest="$2"
  if need_cmd curl; then
    curl -fsSL "$url" -o "$dest"
  elif need_cmd wget; then
    wget -q "$url" -O "$dest"
  else
    echo "curl or wget is required to download $url" >&2
    exit 1
  fi
}

if [ ! -f "${WRAPPER_JAR}" ]; then
  mkdir -p "${WRAPPER_DIR}"
  echo "Downloading Maven Wrapper jar from ${wrapperUrl}"
  download "${wrapperUrl}" "${WRAPPER_JAR}"
fi

if [ -z "${JAVA_HOME:-}" ]; then
  JAVA_EXE="$(command -v java || true)"
else
  JAVA_EXE="${JAVA_HOME}/bin/java"
fi

if [ ! -x "${JAVA_EXE}" ]; then
  echo "Error: JAVA_HOME is not set and no 'java' command could be found on the PATH." >&2
  exit 1
fi

exec "${JAVA_EXE}" \
  -Dmaven.multiModuleProjectDirectory="${BASE_DIR}" \
  -classpath "${WRAPPER_JAR}" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"

